# ============================================================
# APP TRIGGER
# Sends signal to central deploy workflow when a release
# is published. Only triggers on official releases,
# not on every code push.
#
# HOW TO DEPLOY:
# 1. Push your code to main as normal
# 2. When ready to publish → create a Release in GitHub
#    Releases → Create new release → Tag: v1.0.0 → Publish
# 3. This trigger fires automatically
# 4. Central workflow builds + deploys + registers app
#
# GITEA MIGRATION:
# - Replace github.com with gitea.company.internal
# - Replace cbcbmbtTest with Gitea org name
# - Update API endpoint for Gitea workflow dispatch
# ============================================================

name: Trigger Deploy

on:
  # Only triggers when a release is published
  # Not on every push — developer controls when to deploy
  release:
    types: [published]

jobs:
  trigger:
    # GITEA: replace with self-hosted runner name
    runs-on: ubuntu-latest

    steps:
      # ── Trigger central deploy workflow ───────────────────
      # Sends repo name to ops/deploy.yml
      # ops workflow handles everything else
      # GITEA: replace api.github.com with gitea.company.internal/api/v1
      # GITEA: replace cbcbmbtTest with Gitea org name
      - name: Trigger central deploy
        run: |
          curl -X POST \
            -H "Authorization: token ${{ secrets.REGISTRY_TOKEN }}" \
            -H "Accept: application/vnd.github.v3+json" \
            https://api.github.com/repos/cbcbmbtTest/ops/actions/workflows/deploy.yml/dispatches \
            -d '{"ref":"main","inputs":{"repo":"${{ github.event.repository.name }}"}}'
